%% ============================================================
%% SOC Assist — Chat Analista v3.0 — Pool EXPERTO SOC
%% 66 preguntas (q_001–q_066) en lógica NO LINEAL
%% con preguntas disparadoras, discriminación por pares
%% y profundización por familia
%%
%% GATEWAY (8 Qs — mayor poder discriminante):
%%   q_002  Fuente de alerta
%%   q_008  Malware confirmado
%%   q_057  Phishing confirmado
%%   q_038  Frecuencia de eventos (burst=DDoS)
%%   q_029  Cuenta deshabilitada activa
%%   q_046  Comunicación C2
%%   q_048  Cifrado masivo de archivos
%%   q_027  Privilegio del usuario
%%
%% CATEGORÍAS (INFERENCE_TABLE de chatbot_engine.py):
%%   RANSOMWARE      → q_048=yes (+0.70)
%%   APT / INTRUSION → q_046=yes (+0.65)
%%   PHISHING        → q_057=yes (+0.65)
%%   DDoS            → q_038=burst (+0.70)
%%   INSIDER         → q_029=disabled_active (+0.45)
%%   CREDENTIAL_THEFT→ q_029=disabled_active (+0.35)
%%   UNKNOWN         → confidence < 0.45
%%
%% MÓDULOS: naturaleza | alcance | activo | usuario |
%%          temporal | evidencia | proteccion | social | identificadores
%%
%% CLASIFICACIÓN: informativo | sospechoso | incidente | critico | brecha
%% ============================================================

%% ─────── ESTILOS ─────────────────────────────────────────────
