CLS_INFO(["⬜  INFORMATIVO   Score < 25
━━━━━━━━━━━━━━━━━━━━━━━━━
Evento de baja probabilidad maliciosa.
Monitorear. No requiere acción inmediata.
MITRE: Ninguna táctica significativa.
Acción: Registrar, observar, enriquecer con TI."]):::r_info

CLS_SOSP(["🟢  SOSPECHOSO   Score 25–49
━━━━━━━━━━━━━━━━━━━━━━━━━
Indicadores ambiguos. Requiere investigación.
MITRE: Reconnaissance | Initial Access
Acción: Escalar a analista Tier 2.
Preservar logs. Verificar con TI adicional."]):::r_sosp

CLS_INCI(["🟡  INCIDENTE   Score 50–74
━━━━━━━━━━━━━━━━━━━━━━━━━
Actividad maliciosa probable o confirmada.
MITRE: Execution | Persistence | Lateral Movement
Acción: Contener equipo afectado.
Notificar al equipo de respuesta.
Iniciar playbook de respuesta a incidentes."]):::r_inci

CLS_CRIT(["🔴  CRÍTICO   Score 75–99
━━━━━━━━━━━━━━━━━━━━━━━━━
Compromiso activo o inminente.
MITRE: Privilege Escalation | Defense Evasion |
       Credential Access | C2 | Exfiltration
Acción: AISLAMIENTO INMEDIATO.
Convocar al equipo de IR. Notificar a dirección.
Preservar evidencia forense."]):::r_crit

CLS_BREC(["🟣  BRECHA   Score ≥ 100
━━━━━━━━━━━━━━━━━━━━━━━━━
Brecha de seguridad confirmada.
MITRE: Impact | Exfiltration | Data Encrypted
Acción: PROTOCOLO DE BRECHA ACTIVO.
Notificación regulatoria (GDPR/LOPD/etc).
IR team + Legal + Dirección + Reguladores.
Comunicación de crisis si hay terceros afectados."]):::r_brec

