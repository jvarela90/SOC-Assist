%% SALIDA UNIFICADA — Clasificación combinada
%% ════════════════════════════════════════════════════════════

subgraph UNIFIED_OUT["🎯  Salida Unificada — Clasificación Combinada"]
direction TB

UNIFIED_SCORE["SCORE UNIFICADO
Si se ejecutaron ambas fases:
  Score final = max(score_fase1_escalado, score_fase2)
  Clasificación técnica = score_fase2 (más precisa)
  Contexto ciudadano = fase1 (evidencia, acciones tomadas)
  Incident en DB = campos de ambas fases combinados

Campos del Incident enriquecidos por Fase 1:
  network_context   ← N-IoCs (IPs, URLs, MACs)
  ti_enrichment     ← TI lookup de IoCs de Fase 1
  tags              ← categorías N: ['ransomware','p1',...]
  attachments       ← evidencias subidas por el ciudadano
  description       ← resumen narrativo generado en Fase 1

Campos del Incident enriquecidos por Fase 2:
  final_score       ← score q_ (motor de scoring)
  final_classification ← informativo/sospechoso/incidente/critico/brecha
  threat_classification ← JSON multidimensional (flow3)
  mitre_tactics     ← ATT&CK mapping automático"]:::bridge

end

